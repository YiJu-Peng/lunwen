<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hardlin.springbootinit.mapper.SubjectMapper">

    <resultMap id="BaseResultMap" type="com.hardlin.springbootinit.model.entity.Subject">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="subjectName" column="subjectName" jdbcType="VARCHAR"/>
            <result property="subjectDes" column="subjectDes" jdbcType="VARCHAR"/>
            <result property="subjectScore" column="subjectScore" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,subjectName,subjectDes,
        subjectScore
    </sql>
</mapper>
